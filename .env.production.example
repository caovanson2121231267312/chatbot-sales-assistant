# ============================================================
# .env.production - Cấu hình môi trường Production
# ============================================================
# QUAN TRỌNG: Không commit file này lên Git!
# Thêm .env.production vào .gitignore
# ============================================================

# ── Database ──────────────────────────────────────────────
# Nếu dùng MySQL trong Docker (service "mysql" trong compose):
DB_HOST=mysql
DB_PORT=3306
DB_NAME=ecommerce_chatbot
DB_USER=rasa
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

# Nếu dùng MySQL bên ngoài (server riêng):
# DB_HOST=192.168.1.100
# DB_PORT=3306

# ── Rasa ──────────────────────────────────────────────────
RASA_PORT=5005
ACTION_SERVER_PORT=5055

# CORS: Thay * bằng domain thật để bảo mật hơn
# Ví dụ: https://myshop.vn,https://www.myshop.vn
RASA_CORS_ORIGINS=*

# ── Docker Image ──────────────────────────────────────────
DOCKER_IMAGE_PREFIX=your-dockerhub-username
APP_VERSION=latest

# ── Nginx Ports ───────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443
